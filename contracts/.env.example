# Contracts/.env is OPTIONAL for the Sui Move build.
#
# `sui client` reads its own ~/.sui config (active address, RPC, env).
# The Move packages here are deployed via `./deploy.sh testnet`, which
# uses whatever `sui client active-env` returns.
#
# You only need this file if you want CI to run `sui client publish`
# from a service account — set SUI_PRIVATE_KEY and override the
# faucet/RPC below.

# Sui Ed25519 private key (bech32: starts with `suiprivkey1...`)
# Generate via:  sui client new-address ed25519 && sui keytool export <addr>
SUI_PRIVATE_KEY=suiprivkey1...

# Override the default Sui CLI env (mainnet | testnet | devnet)
SUI_ACTIVE_ENV=testnet

# Optional: pin a Tatum-backed RPC for `sui client` (otherwise it uses
# the public fullnode). Tatum free tier works for `publish`.
SUI_RPC_URL=https://sui-testnet.gateway.tatum.io
TATUM_API_KEY=

# Protocol wallet that becomes the Registry's `protocol_wallet` on init.
# Defaults to whoever publishes the package; set this only if you want
# a separate treasury address.
TALOS_PROTOCOL_WALLET=0x...
