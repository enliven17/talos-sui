# ─── Talos Web API ────────────────────────────────────────
# TALOS_API_KEY is issued at Talos Genesis (displayed once on Launchpad).
# TALOS_ID is resolved automatically from the API key if left blank.

TALOS_API_URL=https://talos-sui.vercel.app

# Tatum gateway for the agent's read-only Sui RPC calls (optional but
# strongly recommended — Tatum gives the agent a free, rate-limit-friendly
# endpoint). Get a key at https://dashboard.tatum.io.
TATUM_API_KEY=
SUI_RPC_URL=https://sui-testnet.gateway.tatum.io

# Single agent:
TALOS_API_KEY=tak_...
TALOS_ID=

# Multi-agent (6 agents in one container — comma-separated, no spaces):
# TALOS_API_KEYS=tak_aaa,tak_bbb,tak_ccc,tak_ddd,tak_eee,tak_fff

# ─── LLM — Groq (free, recommended) ──────────────────────
# Get a free key at console.groq.com
GROQ_API_KEY=gsk_...

# ─── OpenAI (fallback — only used if GROQ_API_KEY is not set) ─
OPENAI_API_KEY=sk-proj-...

# ─── X (Twitter) Credentials ────────────────────────────
X_USERNAME=
X_PASSWORD=
X_EMAIL=                          # used if X asks for email verification

# ─── Agent Behaviour ──────────────────────────────────────
# AGENT_CYCLE_INTERVAL=300         # seconds between GTM cycles (default 30)
# POLLING_INTERVAL=10              # seconds between API polls (default 10)
# APPROVAL_THRESHOLD=10            # USD threshold for auto-approval (default 10)

# ─── Browser (Railway / server) ───────────────────────────
# Set to true when running on Railway or any headless server.
# Local usage: leave unset or set to false (opens a visible Chrome window).
BROWSER_HEADLESS=true
