# ─── Database (Neon serverless Postgres) ─────────────────
# Create a project at https://console.neon.tech and copy the
# *pooled* connection string (look for `-pooler` in the host).
# Drizzle migrations and the Next.js runtime both use this URL.
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.neon.tech/talos?sslmode=require

# ─── Sui Network ──────────────────────────────────────────
# Set to mainnet | testnet | devnet
SUI_NETWORK=testnet

# Tatum-backed RPC gateway (omit SUI_RPC_URL to auto-pick by SUI_NETWORK).
# Get a free key at https://dashboard.tatum.io
TATUM_API_KEY=
SUI_RPC_URL=https://sui-testnet.gateway.tatum.io

# NEXT_PUBLIC_ variants are required for client-side dApp Kit setup.
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_RPC_URL=https://sui-testnet.gateway.tatum.io

# ─── USDC Coin Type ───────────────────────────────────────
# Override the network default if you use a different USDC deployment
# (e.g. native CCTP vs Wormhole-wrapped).
# USDC_COIN_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC

# ─── Sui Operator (Server-side signing) ──────────────────
# Generated via: sui client new-address ed25519 && sui keytool export <addr>
# Stored ONLY here on the server — never sent to clients or the Python agent.
SUI_OPERATOR_SECRET_KEY=suiprivkey1...
SUI_OPERATOR_ADDRESS=0x...

# ─── Per-agent Sui secret keys ───────────────────────────
# Format: TALOS_AGENT_SECRET_<talos_id>=suiprivkey1...
# Used by /api/talos/:id/sign and /api/talos/:id/transfer.
# TALOS_AGENT_SECRET_clk123abc=suiprivkey1...

# ─── Sui Move Packages ───────────────────────────────────
# Run: cd contracts && ./deploy.sh testnet — copy the printed values here.
NEXT_PUBLIC_TALOS_REGISTRY_PACKAGE=0x...
NEXT_PUBLIC_TALOS_REGISTRY_OBJECT=0x...
NEXT_PUBLIC_TALOS_NAME_SERVICE_PACKAGE=0x...
NEXT_PUBLIC_TALOS_NAME_SERVICE_OBJECT=0x...

# ─── Talos Badges (NFT mint operator) ────────────────────
# Publish via: cd contracts && sui client publish --gas-budget 200000000 talos_badges
# Then grep the output for PackageID and MinterCap.
TALOS_BADGES_PACKAGE=0x...
TALOS_BADGES_MINTER_CAP=0x...
NEXT_PUBLIC_TALOS_BADGES_PACKAGE=0x...

# ─── Walrus Decentralized Storage ────────────────────────
# Default to the public Walrus testnet endpoints; override to use your own.
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=5

# NEXT_PUBLIC_ variants for client-side uploads from the launchpad
NEXT_PUBLIC_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_EPOCHS=5

# ─── AI Services ──────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-...

# ─── Talos Genesis ────────────────────────────────────────
NEXT_PUBLIC_TALOS_CREATION_SUI=2
