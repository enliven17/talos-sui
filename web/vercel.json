{
  "framework": "nextjs",
  "regions": ["iad1"],
  "outputDirectory": ".next",

  "installCommand": "pnpm install --frozen-lockfile --ignore-workspace",
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",

  "env": {
    "NODE_ENV": "production"
  },

  "build": {
    "env": {
      "ENABLE_EXPERIMENTAL_COREPACK": "1"
    }
  }
}
